pipeline {
    agent any

    stages {
        stage('Nettoyage Workspace') {
            steps {
                cleanWs()
            }
        }
        
        stage('Checkout SCM') {
            steps {
                git branch: 'main', url: 'https://github.com/ThomasDufour78/githubeval.git'
            }
        }

        stage('Création du Dockerfile') {
            steps {
                writeFile file: 'Dockerfile', text: '''
FROM ubuntu:latest

RUN apt-get update && apt-get install -y \
    nginx \
    net-tools \
    iproute2 \
    python3 \
    iputils-ping

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
'''
            }
        }
        
        stage('Build DockerImage') {
            steps {
                sh 'docker build -t mon-image-ubuntu .'
            }
        }
        
        stage('Deploy application') {
            steps {
                sh 'docker stop mon-conteneur || true'
                sh 'docker rm mon-conteneur || true'
                sh 'docker run -d -p 80:80 --name mon-conteneur mon-image-ubuntu'
            }
        }
    }
}
