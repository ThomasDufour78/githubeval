pipeline {
    agent any

    stages {

        stage('Nettoyage Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout SCM') {
            steps {
                git branch: 'main', url: 'https://github.com/ThomasDufour78/githubeval.git'
            }
        }

        stage('Test Node') {
            agent {
                docker {
                    image 'node:22.17.0-alpine3.22'
                }
            }
            steps {
                sh 'node --version'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t app-devops .'
            }
        }

        stage('Deploy application') {
            steps {
                sh 'docker stop site-web || true'
                sh 'docker rm site-web || true'
                sh 'docker run -d -p 80:80 --name site-web app-devops'
            }
        }
    }
}
