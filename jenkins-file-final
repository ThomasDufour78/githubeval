pipeline {
    agent any

    environment {
        IMAGE_NAME = "my-nginx"
        CONTAINER_NAME = "myapp"
    }

    stages {

        stage('1. Nettoyage Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('2. Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/ThomasDufour78/githubeval.git'
            }
        }

        stage('3. Vérification Docker') {
            steps {
                sh '''
                    docker --version
                    docker info
                '''
            }
        }

        stage('4. Build Image Docker') {
            steps {
                sh '''
                    docker build -t $IMAGE_NAME .
                '''
            }
        }

        stage('5. Stop & Remove ancien container') {
            steps {
                sh '''
                    docker stop myapp || true
                    docker rm myapp || true
                '''
            }
        }

        stage('6. Déploiement') {
            steps {
                sh '''
                    docker run -d \
                        --name myapp \
                        -p 80:80 \
                        $IMAGE_NAME

                    sleep 2

                    docker cp monsite/. myapp:/usr/share/nginx/html/
                '''
            }
        }
    }

    post {
        success {
            echo "Déploiement réussi"
        }

        failure {
            echo "Échec du pipeline"
        }

        always {
            echo "Fin du pipeline"
        }
    }
}
